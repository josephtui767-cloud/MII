# Database
DATABASE_URL=postgresql+asyncpg://mii:password@db:5432/mii

# Application
APP_ENV=development
LOG_LEVEL=INFO

# AWS (for identity discovery)
# MII uses boto3 default credential chain. Set these OR use ~/.aws/credentials OR EC2 instance role.
AWS_REGION=eu-central-1
AWS_ACCOUNT_IDS=123456789012
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: cross-account role ARN (if scanning accounts you don't directly have creds for)
AWS_ASSUME_ROLE_ARN=

# GitLab (optional — for GitLab CI/CD identity discovery)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=

# OpenAI (optional — for AI features)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
