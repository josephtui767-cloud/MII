# Database
DATABASE_URL=postgresql+asyncpg://mii:password@db:5432/mii

# Application
APP_ENV=development
LOG_LEVEL=INFO

# AWS (for identity discovery)
# MII uses boto3 default credential chain. Set these OR use ~/.aws/credentials OR EC2 instance role.
AWS_REGION=eu-central-1
# Option A: List specific accounts (comma-separated)
AWS_ACCOUNT_IDS=123456789012
# Option B: Auto-discover all accounts via AWS Organizations
# AWS_ACCOUNT_IDS=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: cross-account role ARN (MII swaps account ID for each target account)
AWS_ASSUME_ROLE_ARN=
# Optional: role to assume for listing Organizations accounts (only needed with AWS_ACCOUNT_IDS=auto)
AWS_ORG_ROLE_ARN=

# GitLab (optional — for GitLab CI/CD identity discovery)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=

# OpenAI (optional — for AI features)
# Works with any OpenAI-compatible API (Azure OpenAI, Ollama, LiteLLM, vLLM, etc.)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Change this to use a different provider:
# OPENAI_BASE_URL=https://api.openai.com/v1          # Default (OpenAI)
# OPENAI_BASE_URL=https://YOUR.openai.azure.com/     # Azure OpenAI
# OPENAI_BASE_URL=http://localhost:11434/v1           # Ollama (local)
# OPENAI_BASE_URL=http://localhost:4000/v1            # LiteLLM proxy
OPENAI_BASE_URL=https://api.openai.com/v1
