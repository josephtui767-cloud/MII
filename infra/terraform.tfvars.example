# Required — Container registry
container_image              = "ghcr.io/YOUR_ORG/mii-backend:latest"
container_registry_username  = "YOUR_GITHUB_USERNAME"
container_registry_password  = "ghp_YOUR_GITHUB_PAT"

# Required — AWS
aws_region      = "eu-central-1"
aws_account_ids = "123456789012"

# Required — Database
db_password = "your-secure-random-password"

# Optional — GitHub org (for OIDC demo trust policies)
github_org = "your-github-org"

# Optional — GitLab (for identity discovery)
gitlab_token = ""

# Optional — AI features
openai_api_key = ""

# Optional — SSH key for EC2 access
key_name = ""
